{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "AetherForge",
    "version": "1.0.0",
    "identifier": "com.aetherforge.app",
    "build": {
        "beforeDevCommand": "npm run dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "npm run build",
        "frontendDist": "../frontend/dist"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "title": "AetherForge — Local AI OS",
                "label": "main",
                "width": 1440,
                "height": 900,
                "minWidth": 1024,
                "minHeight": 700,
                "resizable": true,
                "fullscreen": false,
                "decorations": true,
                "center": true,
                "visible": true,
                "url": "index.html"
            }
        ],
        "security": {
            "csp": "default-src 'self' http://localhost:8765 ws://localhost:8765; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: https://asset.localhost"
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "macOS": {
            "minimumSystemVersion": "12.0",
            "signingIdentity": null,
            "providerShortName": null,
            "frameworks": [],
            "infoPlist": {
                "NSMicrophoneUsageDescription": "AetherForge uses microphone for voice commands",
                "NSCameraUsageDescription": "AetherForge does not use the camera"
            }
        }
    },
    "plugins": {
        "shell": {
            "open": true,
            "scope": []
        },
        "dialog": {},
        "notification": {
            "all": true
        }
    }
}